generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Target {
  id        String   @id @default(cuid())
  name      String
  platform  String   @default("independent") // hackerone, bugcrowd, intigriti, independent
  url       String?
  scope     String?  // markdown text for scope details
  status    String   @default("recon") // recon, hunting, reported, idle
  notes     String?  // recon notes, markdown
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  findings           Finding[]
  journals           Journal[]
  checklistInstances ChecklistInstance[]
}

model Finding {
  id          String   @id @default(cuid())
  title       String
  targetId    String
  target      Target   @relation(fields: [targetId], references: [id], onDelete: Cascade)
  vulnType    String   // xss, sqli, idor, ssrf, rce, lfi, open-redirect, info-disclosure, etc
  severity    String   @default("medium") // critical, high, medium, low, info
  status      String   @default("draft") // draft, reported, triaged, accepted, resolved, duplicate, na
  bounty      Float    @default(0)
  poc         String?  // proof of concept steps, markdown
  endpoint    String?  // affected endpoint/url
  reportUrl   String?  // link to report on platform
  foundAt     DateTime @default(now())
  reportedAt  DateTime?
  triagedAt   DateTime?
  resolvedAt  DateTime?
  images      String?  // JSON array of image URLs from Vercel Blob
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Checklist {
  id        String   @id @default(cuid())
  name      String
  vulnType  String?  // linked vuln type, or null for general
  items     String   // JSON array of checklist item strings
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  instances ChecklistInstance[]
}

model ChecklistInstance {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  targetId    String
  target      Target    @relation(fields: [targetId], references: [id], onDelete: Cascade)
  checked     String    @default("[]") // JSON array of booleans
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([checklistId, targetId])
}

model Journal {
  id        String   @id @default(cuid())
  date      DateTime @default(now())
  targetId  String?
  target    Target?  @relation(fields: [targetId], references: [id], onDelete: SetNull)
  content   String   // markdown
  tags      String?  // comma-separated tags
  images    String?  // JSON array of image URLs from Vercel Blob
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
